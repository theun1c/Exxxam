<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LearnSchoolAvalonia.Components.ServiceCard"
             xmlns:models="using:LearnSchoolAvalonia.Models"
             x:DataType="models:Service">
      <Border BorderBrush="Gray" BorderThickness="2" Margin="10,10,10,0">          
          
      
        <Grid ColumnDefinitions="80, *" Margin="10">
            <Image Grid.Column="0" VerticalAlignment="Center" Stretch="UniformToFill" Width="100" Height="100" Source="{Binding ImageBitmap}" Margin="0, 0, 20, 0"/>
            <StackPanel Grid.Column="1" >

            <TextBlock Text="{Binding ImageBitmap}"/>
        

                  <TextBlock FontSize="20" Text="{Binding Name}"/>

                  <StackPanel Orientation="Horizontal" Margin="0, 5">
                          <TextBlock FontSize="18" Text="{Binding Cost, StringFormat='{}{0} рублец'}"/>   
                  
                          <TextBlock FontSize="18" Margin="8, 0, 0, 0" Text="{Binding DurationMinutes, StringFormat='{}за {0} минут'}"/>
                        
                      

                    </StackPanel>

                <StackPanel Orientation="Horizontal">
               
                            <Button Content="редактировать" Background="CadetBlue"/>
                            <Button Content="удалить" Margin="10,0" Background="IndianRed"/>
                        </StackPanel>
             </StackPanel>

        </Grid>

        
      </Border>

</UserControl>
